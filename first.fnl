;; script:  fennel
;; strict:  true

(var t 0)
(var x 96)
(var y 24)

(fn _G.TIC []
  (when (btn 0) (set y (- y 1)))
  (when (btn 1) (set y (+ y 1)))
  (when (btn 2) (set x (- x 1)))
  (when (btn 3) (set x (+ x 1)))
  (when (and (and (<= 220 x)
                  (<= x 225))
             (and (<= 20 y)
                  (<= y 25))) (set x 20))
  (cls 0)
  (map 0 0 2 2 0 0)
  
  ;; vents
  (spr 259 20 20 -1 2 0 0 1 1)
  (spr 259 220 20 -1 2 0 0 1 1)

  ;; amongus
  (spr (+ 257 (* (// (% t 60) 30) 2))
       x y 14 3 0 0 1 1)
  
  (print "when imposter is sus" 84 84)
  (print "bum bum bum" 84 90))
  

