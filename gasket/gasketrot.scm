(define t 0)

(define (pal c0 c1)
  "Palette swap helper."
  (if (and (not c0) (not c1))
      (do ((i 0 (+ i 1)))
	  ((> i 15))
	(poke4 (+ i (* #x3FF0 2)) i))
      (poke4 (+ c0 (* #x3FF0 2)) c1)))

